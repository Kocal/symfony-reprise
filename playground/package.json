{
  "type": "module",
  "private": true,
  "scripts": {
    "vite:dev": "nodemon -w '../src/**/*.ts' -e .ts -x vite",
    "vite:build": "nodemon -w '../src/**/*.ts' -e .ts -x vite build",
    "rsbuild:dev": "nodemon -w '../src/**/*.ts' -e .ts -x rsbuild dev",
    "rsbuild:build": "nodemon -w '../src/**/*.ts' -e .ts -x rsbuild build"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.5",
    "vite": "^8.1.3",
    "vite-plugin-inspect": "^11.1.0"
  }
}
