  "homepage": "https://github.com/kocal/unplugin-symfony#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kocal/unplugin-symfony.git"
  },
  "bugs": {
    "url": "https://github.com/kocal/unplugin-symfony/issues"
  },
  "keywords": [
    "unplugin",
    "vite",
    "rsbuild",
    "symfony"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./rspack": "./dist/rspack.js",
    "./types": "./dist/types.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
