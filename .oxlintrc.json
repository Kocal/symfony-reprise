{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["eslint", "typescript", "unicorn", "node"],
    "categories": {},
    "rules": {},
    "env": {
        "builtin": true
    },
    "globals": {},
    "ignorePatterns": [
        "**/composer.json",
        "**/vendor",
        "**/package.json",
        "**/node_modules",
        ".agents/skills",
        ".github/PULL_REQUEST_TEMPLATE.md",
